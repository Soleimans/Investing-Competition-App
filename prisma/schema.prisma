generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole {
  OWNER
  MEMBER
}

enum CompetitionVisibility {
  PRIVATE
  PUBLIC
}

enum TransactionSide {
  BUY
}

enum AssetType {
  STOCK
  CASH
}

model User {
  id                  String                @id @default(cuid())
  name                String                @unique
  passwordHash        String
  profileImageDataUrl String?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  createdCompetitions Competition[]         @relation("CompetitionCreator")
  memberships         CompetitionMember[]
  transactions        InvestmentTransaction[]
  portfolioSnapshots  PortfolioSnapshot[]
  sessions            Session[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Competition {
  id                  String                  @id @default(cuid())
  name                String
  slug                String                  @unique
  description         String?
  createdById         String
  startDate           DateTime
  endDate             DateTime?
  currency            String                  @default("EUR")
  visibility          CompetitionVisibility   @default(PRIVATE)
  joinCode            String                  @unique
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  createdBy           User                    @relation("CompetitionCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members             CompetitionMember[]
  transactions        InvestmentTransaction[]
  portfolioSnapshots  PortfolioSnapshot[]

  @@index([createdById])
}

model CompetitionMember {
  id             String       @id @default(cuid())
  competitionId  String
  userId         String
  role           MemberRole   @default(MEMBER)
  joinedAt       DateTime     @default(now())
  pinned         Boolean      @default(false)
  lastVisitedAt  DateTime?
  competition    Competition  @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([competitionId, userId])
  @@index([userId, pinned])
  @@index([userId, lastVisitedAt])
}

model InvestmentTransaction {
  id              String          @id @default(cuid())
  competitionId   String
  userId          String
  assetType       AssetType       @default(STOCK)
  ticker          String
  companyName     String?
  side            TransactionSide @default(BUY)
  quantity        Decimal         @db.Decimal(18, 6)
  pricePerShare   Decimal         @db.Decimal(18, 6)
  quoteCurrency   String          @default("USD")
  executedAt      DateTime
  note            String?
  createdAt       DateTime        @default(now())
  competition     Competition     @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId, executedAt])
  @@index([userId, competitionId])
  @@index([ticker])
}

model SymbolPriceSnapshot {
  id          String   @id @default(cuid())
  ticker      String
  price       Decimal  @db.Decimal(18, 6)
  currency    String   @default("USD")
  source      String
  fetchedAt   DateTime @default(now())

  @@index([ticker, fetchedAt])
}

model PortfolioSnapshot {
  id             String      @id @default(cuid())
  competitionId  String
  userId         String
  totalValue     Decimal     @db.Decimal(18, 6)
  totalCost      Decimal     @db.Decimal(18, 6)
  pnl            Decimal     @db.Decimal(18, 6)
  snapshottedAt  DateTime    @default(now())
  competition    Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([competitionId, snapshottedAt])
  @@index([competitionId, userId, snapshottedAt])
}
